# MongoDB settings
MONGO_USER=your_username_here
MONGO_PASSWORD=your_password_here
MONGO_HOST=name_of_your_host
MONGO_DB=name_of_your_database
MONGO_PORT=27017
MONGO_URI=mongodb+srv:your_uri_for_mongodb

# JWT settings
SECRET_KEY=your_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30


#Stripe key secret
STRIPE_SECRET_KEY=sk_your_stripe_secret_key_here
#Loki endpoint environment
LOKI_ENDPOINT=your_loki_endpoint_here

# Logging configuration
DOCS_USER=username_for_docs_user_here
DOCS_PASSWORD=password_for_docs_user_here